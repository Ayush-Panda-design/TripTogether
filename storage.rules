rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /avatars/{uid}/{file=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /trips/{tripId}/{file=**} {
      allow read: if request.auth != null
        && firestore.exists(/databases/(default)/documents/trips/$(tripId)/members/$(request.auth.uid));
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/trips/$(tripId)/members/$(request.auth.uid)).data.role in ['owner','editor'];
    }
  }
}
